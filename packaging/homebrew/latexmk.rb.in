class Latexmk < Formula
  desc "Python port of latexmk"
  homepage "https://github.com/example/py-latexmk"
  url "__URL__"
  sha256 "__SHA256__"
  version "__VERSION__"

  def install
    bin.install Dir["latexmk*"].first => "latexmk"
  end

  test do
    assert_match "latexmk", shell_output("#{bin}/latexmk --version")
  end
end
